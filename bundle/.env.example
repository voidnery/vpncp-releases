# =============================================================================
# VPN Control Plane — environment configuration
# Copy this file to `.env` and replace all CHANGE_ME values.
# Generate secrets with: ./scripts/generate-secrets.sh
# =============================================================================

# --- Environment ---
NODE_ENV=production
LOG_LEVEL=info

# --- Public URL of the panel (used in agent enrollment & client configs) ---
# Example: https://panel.example.com
PUBLIC_DOMAIN=panel.example.com
PUBLIC_API_URL=https://panel.example.com

# --- Bootstrap superadmin (used only on first start) ---
# After first start, change password via UI. This value is ignored later.
BOOTSTRAP_ADMIN_USERNAME=root
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- API ---
API_PORT=4000
AGENT_API_PORT=4001
AGENT_PUBLIC_PORT=8443
# Comma-separated list of allowed origins for CORS (panel UI)
ALLOWED_ORIGINS=https://panel.example.com

# --- MongoDB ---
MONGO_USER=vpncp
MONGO_PASS=CHANGE_ME_MONGO_PASSWORD
MONGO_DB=vpncp
# This URI is built from the above for the API container:
MONGO_URI=mongodb://vpncp:CHANGE_ME_MONGO_PASSWORD@mongo:27017/vpncp?authSource=admin

# --- Redis (queues + cache) ---
REDIS_PASS=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://default:CHANGE_ME_REDIS_PASSWORD@redis:6379

# --- Crypto ---
# 32 bytes base64 — used to encrypt VPN credentials at rest (AES-256-GCM).
# Generate: openssl rand -base64 32
# CRITICAL: backup this key OFFLINE. If lost, all stored credentials are unrecoverable.
MASTER_KEY=CHANGE_ME_MASTER_KEY_BASE64

# JWT secrets (different for access & refresh)
# Generate: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_JWT_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Cookie secret for signed cookies
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET

# Agent enrollment HMAC secret (signs one-time enrollment tokens)
ENROLLMENT_SECRET=CHANGE_ME_ENROLLMENT_SECRET

# --- License (optional) ---
# Paste a VPNCP1 license token to activate your tier on first boot. Leave empty
# to start in FREE mode and install the license later via the UI (License page).
VPNCP_LICENSE=

# --- TLS / Certificates ---
# Set to 'letsencrypt' for production with valid domain,
# or 'self-signed' for local/IP-based deployments.
TLS_MODE=letsencrypt
LETSENCRYPT_EMAIL=admin@example.com

# --- Backups ---
BACKUP_DIR=/var/backups/vpncp
BACKUP_RETENTION_DAYS=30
# Passphrase for encrypting backups with age
BACKUP_PASSPHRASE=CHANGE_ME_BACKUP_PASSPHRASE
