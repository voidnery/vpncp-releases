# Bootstrap config: serves HTTP only, used during initial certbot challenge.
# After ./scripts/cert.sh succeeds, this is replaced by default.conf (HTTPS).

server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    # ACME challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Everything else — proxy to web (for initial setup without HTTPS)
    location / {
        proxy_pass http://web:80;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /api/ {
        proxy_pass http://api:4000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
