# =============================================================================
# NET-Control — Synology environment.
# Copy to `.env` next to docker-compose.synology.yml and fill every CHANGE_ME.
#
# Generate the secrets quickly (over SSH on the NAS, or on any machine):
#   ./scripts/generate-secrets.sh            # fills MASTER_KEY/JWT/Mongo/Redis...
# or by hand, each:  openssl rand -base64 32
# =============================================================================

NODE_ENV=production
LOG_LEVEL=info

# --- Distribution images (published by CI to GHCR) ---
# Owner must be lowercase. Pin a version for reproducible installs; "stable"
# always tracks the latest stable release.
VPNCP_REGISTRY=ghcr.io/voidnery
VPNCP_VERSION=stable

# --- Panel port on the NAS ---
# DSM owns 80/443, so the panel uses a high TLS port. Forward this port on your
# router to the NAS so remote agents (on your VPN servers) can reach the panel.
PANEL_PORT=8443

# --- Public address of the panel ---
# Used for agent enrollment URLs and generated client configs (NOT the SPA, which
# is same-origin). Use your DDNS/host name and the panel port. IP also works.
PUBLIC_DOMAIN=nas.example.synology.me
PUBLIC_API_URL=https://nas.example.synology.me:8443
ALLOWED_ORIGINS=https://nas.example.synology.me:8443

# --- Bootstrap superadmin (first start only; change in UI afterwards) ---
BOOTSTRAP_ADMIN_USERNAME=root
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- API ports (internal; do not change unless you also edit synology.conf) ---
API_PORT=4000
AGENT_API_PORT=4001
AGENT_PUBLIC_PORT=8443

# --- MongoDB ---
MONGO_USER=vpncp
MONGO_PASS=CHANGE_ME_MONGO_PASSWORD
MONGO_DB=vpncp
MONGO_URI=mongodb://vpncp:CHANGE_ME_MONGO_PASSWORD@mongo:27017/vpncp?authSource=vpncp

# --- Redis (queues + cache) ---
REDIS_PASS=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://default:CHANGE_ME_REDIS_PASSWORD@redis:6379

# --- Crypto ---
# 32 bytes base64. Encrypts VPN credentials at rest (AES-256-GCM).
# CRITICAL: back this up OFFLINE. If lost, stored credentials are unrecoverable.
MASTER_KEY=CHANGE_ME_MASTER_KEY_BASE64

JWT_ACCESS_SECRET=CHANGE_ME_JWT_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET
ENROLLMENT_SECRET=CHANGE_ME_ENROLLMENT_SECRET

# --- License (optional) ---
# Paste a VPNCP1 token to activate your tier on first boot, or leave empty and
# add it later via the UI (Суперадмин → Лицензия).
VPNCP_LICENSE=
